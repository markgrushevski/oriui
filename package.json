{
    "name": "oriui",
    "description": "oriUI monorepo (織り) — @oriui/vue styled components, @oriui/headless behavior, @oriui/css standalone styles, and the docs site",
    "license": "MIT",
    "version": "1.0.0-alpha.1",
    "private": true,
    "type": "module",
    "engines": {
        "node": ">=20.19.0"
    },
    "author": {
        "name": "Leonid",
        "email": "markgrushevski@gmail.com",
        "url": "https://github.com/markgrushevski"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/markgrushevski/oriui.git"
    },
    "bugs": {
        "url": "https://github.com/markgrushevski/oriui/issues"
    },
    "homepage": "https://oriui.vercel.app",
    "workspaces": [
        "docs",
        "packages/*"
    ],
    "scripts": {
        "dev": "npm run dev --workspace docs",
        "types": "npm run types --workspaces --if-present",
        "build": "npm run build:packages",
        "build:packages": "npm run build -w @oriui/css && npm run build -w @oriui/headless && npm run build -w @oriui/vue",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:cov": "vitest run --coverage",
        "test:types": "vue-tsc -p tsconfig.vitest.json --noEmit",
        "lint:prettier": "npx prettier --write **/*.{vue,js,ts,json,md,html,css}",
        "lint:stylelint": "npx stylelint --fix \"packages/vue/src/**/*.{vue,css}\" \"packages/css/src/**/*.css\"",
        "lint:eslint": "npx eslint --fix \"packages/*/src/**/*.{vue,ts}\"",
        "lint:all": "npm run lint:prettier && npm run lint:stylelint && npm run lint:eslint",
        "lint:ci": "prettier --check \"**/*.{vue,js,ts,json,md,html,css}\" && stylelint \"packages/vue/src/**/*.{vue,css}\" \"packages/css/src/**/*.css\" && eslint \"packages/*/src/**/*.{vue,ts}\"",
        "prepare": "husky",
        "changeset": "changeset",
        "version": "changeset version && npm install --package-lock-only",
        "release": "npm run build && changeset publish --tag next",
        "docs:dev": "npm run dev --workspace docs",
        "docs:build": "npm run generate --workspace docs",
        "docs:preview": "npm run preview --workspace docs"
    },
    "devDependencies": {
        "@changesets/cli": "^2.31.0",
        "@eslint/js": "^10.0.1",
        "@types/node": "^26.0.1",
        "@vitejs/plugin-vue": "^6.0.7",
        "@vitest/coverage-v8": "^4.1.9",
        "@vue/test-utils": "^2.4.11",
        "axe-core": "^4.12.1",
        "eslint": "^10.6.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-vue": "^10.9.2",
        "globals": "^17.7.0",
        "happy-dom": "^20.10.6",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.8",
        "postcss": "^8.5.16",
        "postcss-html": "^1.8.1",
        "prettier": "^3.9.4",
        "stylelint": "^17.14.0",
        "stylelint-config-property-sort-order-smacss": "^11.2.0",
        "stylelint-config-standard-vue": "^1.0.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.62.1",
        "vite": "^8.1.2",
        "vitest": "^4.1.9",
        "vue": "^3.5.39",
        "vue-eslint-parser": "^10.4.1",
        "vue-tsc": "^3.3.6"
    }
}
