{
    "name": "oriui",
    "description": "Layered Vue 3 UI library: styled components + headless behavior + standalone CSS design system (織り)",
    "license": "MIT",
    "version": "1.0.0-alpha.0",
    "type": "module",
    "engines": {
        "node": ">=20.19.0"
    },
    "author": {
        "name": "Leonid",
        "email": "markgrushevski@gmail.com",
        "url": "https://github.com/markgrushevski"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/markgrushevski/vueinjar.git"
    },
    "bugs": {
        "url": "https://github.com/markgrushevski/vueinjar/issues"
    },
    "files": [
        "dist"
    ],
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "sideEffects": [
        "**/*.css"
    ],
    "scripts": {
        "dev": "vite",
        "types": "vue-tsc --noEmit",
        "types:watch": "vue-tsc --noEmit --watch",
        "build": "vite build && vue-tsc -p tsconfig.build.json",
        "build:watch": "vite build --watch",
        "lint:prettier": "npx prettier --write **/*.{vue,js,ts,json,md,html,css}",
        "lint:stylelint": "npx stylelint --fix src/**/*.{vue,css}",
        "lint:eslint": "npx eslint --fix src/**/*.{vue,ts}",
        "lint:all": "npm run lint:prettier && npm run lint:stylelint && npm run lint:eslint",
        "prepare": "husky",
        "prepack": "npm run build",
        "docs:dev": "vitepress dev docs",
        "docs:build": "vitepress build docs",
        "docs:preview": "vitepress preview docs"
    },
    "peerDependencies": {
        "vue": "^3"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^24",
        "@vitejs/plugin-vue": "^6.0.7",
        "autoprefixer": "^10.4.23",
        "eslint": "^10.5.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-vue": "^10.9.2",
        "globals": "^17.6.0",
        "husky": "^9.1.7",
        "lint-staged": "^16",
        "postcss-html": "^1.8.0",
        "prettier": "^3.8.4",
        "stylelint": "^17.13.0",
        "stylelint-config-property-sort-order-smacss": "^11.2.0",
        "stylelint-config-standard-vue": "^1.0.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.61.0",
        "vite": "^8.0.16",
        "vite-plugin-lib-inject-css": "^2.2.2",
        "vitepress": "^1.6.4",
        "vue-eslint-parser": "^10.4.1",
        "vue-tsc": "^3.3.5"
    }
}
