{
    "name": "@oriui/ui",
    "description": "Layered Vue 3 UI library: styled components + headless behavior + standalone CSS design system (織り)",
    "license": "MIT",
    "version": "1.0.0-alpha.1",
    "type": "module",
    "engines": {
        "node": ">=20.19.0"
    },
    "author": {
        "name": "Leonid",
        "email": "markgrushevski@gmail.com",
        "url": "https://github.com/markgrushevski"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/markgrushevski/oriui.git"
    },
    "bugs": {
        "url": "https://github.com/markgrushevski/oriui/issues"
    },
    "homepage": "https://oriui.vercel.app",
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public"
    },
    "workspaces": [
        "docs",
        "packages/*"
    ],
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "sideEffects": [
        "**/*.css"
    ],
    "scripts": {
        "dev": "npm run dev --workspace docs",
        "types": "vue-tsc --noEmit",
        "types:watch": "vue-tsc --noEmit --watch",
        "build": "npm run build:packages && vite build && vue-tsc -p tsconfig.build.json",
        "build:packages": "npm run build -w @oriui/css && npm run build -w @oriui/core && npm run build -w @oriui/vue",
        "build:watch": "vite build --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:cov": "vitest run --coverage",
        "test:types": "vue-tsc -p tsconfig.vitest.json --noEmit",
        "lint:prettier": "npx prettier --write **/*.{vue,js,ts,json,md,html,css}",
        "lint:stylelint": "npx stylelint --fix \"src/**/*.{vue,css}\" \"packages/css/src/**/*.css\"",
        "lint:eslint": "npx eslint --fix src/**/*.{vue,ts}",
        "lint:all": "npm run lint:prettier && npm run lint:stylelint && npm run lint:eslint",
        "lint:ci": "prettier --check \"**/*.{vue,js,ts,json,md,html,css}\" && stylelint \"src/**/*.{vue,css}\" \"packages/css/src/**/*.css\" && eslint \"src/**/*.{vue,ts}\"",
        "prepare": "husky",
        "prepack": "npm run build",
        "bump": "node scripts/bump.mjs",
        "docs:dev": "npm run dev --workspace docs",
        "docs:build": "npm run generate --workspace docs",
        "docs:preview": "npm run preview --workspace docs"
    },
    "dependencies": {
        "@oriui/css": "1.0.0-alpha.1",
        "@oriui/vue": "1.0.0-alpha.1"
    },
    "peerDependencies": {
        "vue": "^3"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^24",
        "@vitejs/plugin-vue": "^6.0.7",
        "@vitest/coverage-v8": "^4.1.9",
        "@vue/test-utils": "^2.4.11",
        "autoprefixer": "^10.4.23",
        "axe-core": "^4.12.1",
        "eslint": "^10.5.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-vue": "^10.9.2",
        "globals": "^17.6.0",
        "happy-dom": "^20.10.4",
        "husky": "^9.1.7",
        "lint-staged": "^16",
        "postcss": "^8.5.15",
        "postcss-html": "^1.8.0",
        "postcss-import": "^16.1.1",
        "prettier": "^3.8.4",
        "stylelint": "^17.13.0",
        "stylelint-config-property-sort-order-smacss": "^11.2.0",
        "stylelint-config-standard-vue": "^1.0.0",
        "tsdown": "^0.22.2",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.61.0",
        "vite": "^8.0.16",
        "vite-plugin-lib-inject-css": "^2.2.2",
        "vitepress": "^1.6.4",
        "vitest": "^4.1.9",
        "vue-eslint-parser": "^10.4.1",
        "vue-tsc": "^3.3.5"
    }
}
