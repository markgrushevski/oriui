{
    "compilerOptions": {
        "target": "ESNext",
        "ignoreDeprecations": "6.0",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "lib": ["ESNext", "DOM", "DOM.Iterable"],
        "strict": true,
        "declaration": true,
        "skipLibCheck": true,
        "verbatimModuleSyntax": true,
        "isolatedModules": true,
        "esModuleInterop": true
    },
    "include": ["src"]
}
