{
    "name": "@oriui/vue",
    "description": "Styled Vue 3 components for oriUI — ready <Ori*> components composed from the headless behavior (@oriui/headless) + standalone CSS (@oriui/css) layers (織り)",
    "license": "MIT",
    "version": "1.0.0-alpha.13",
    "type": "module",
    "engines": {
        "node": ">=22.18.0"
    },
    "author": {
        "name": "Leonid",
        "email": "markgrushevski@gmail.com",
        "url": "https://github.com/markgrushevski"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/markgrushevski/oriui.git",
        "directory": "packages/vue"
    },
    "bugs": {
        "url": "https://github.com/markgrushevski/oriui/issues"
    },
    "homepage": "https://oriui.vercel.app",
    "files": [
        "dist",
        "src"
    ],
    "publishConfig": {
        "access": "public"
    },
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "sideEffects": [
        "**/*.css"
    ],
    "scripts": {
        "build": "vite build && vue-tsc -p tsconfig.build.json && node scripts/fix-dts.mjs",
        "types": "vue-tsc --noEmit"
    },
    "dependencies": {
        "@oriui/css": "1.0.0-alpha.13",
        "@oriui/headless": "1.0.0-alpha.13"
    },
    "peerDependencies": {
        "vue": "^3"
    }
}
