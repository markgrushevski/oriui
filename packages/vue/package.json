{
    "name": "@oriui/vue",
    "version": "1.0.0-alpha.0",
    "description": "Vue 3 adapter for the oriUI headless layer — composables over @oriui/core",
    "license": "MIT",
    "type": "module",
    "sideEffects": false,
    "files": [
        "dist"
    ],
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "tsdown",
        "types": "tsc --noEmit"
    },
    "peerDependencies": {
        "vue": "^3.5"
    },
    "dependencies": {
        "@oriui/core": "*"
    }
}
