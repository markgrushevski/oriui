{
    "name": "@oriui/css",
    "version": "1.0.0-alpha.13",
    "description": "Standalone CSS design tokens + .ori-* utility classes for oriUI — no framework, no build step",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/markgrushevski/oriui.git",
        "directory": "packages/css"
    },
    "type": "module",
    "sideEffects": [
        "**/*.css"
    ],
    "files": [
        "dist",
        "src"
    ],
    "publishConfig": {
        "access": "public"
    },
    "style": "./dist/styles.css",
    "exports": {
        ".": "./dist/styles.css",
        "./styles.css": "./dist/styles.css",
        "./base.css": "./dist/base.css",
        "./tokens.css": "./dist/tokens.css",
        "./reset.css": "./dist/reset.css",
        "./components/*.css": "./dist/components/*.css",
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "node build.mjs"
    },
    "devDependencies": {
        "autoprefixer": "^10.5.2",
        "cssnano": "^8.0.2",
        "postcss": "^8.5.16",
        "postcss-import": "^16.1.1"
    }
}
