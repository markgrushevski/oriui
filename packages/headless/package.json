{
    "name": "@oriui/headless",
    "version": "1.0.0-alpha.17",
    "description": "Framework-agnostic headless engine for oriUI + adapters (Vue at ./vue, Svelte at ./svelte, React at ./react) — tiny state machines + prop-getters behind a swappable contract",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/markgrushevski/oriui.git",
        "directory": "packages/headless"
    },
    "type": "module",
    "sideEffects": false,
    "files": [
        "dist",
        "src"
    ],
    "publishConfig": {
        "access": "public"
    },
    "exports": {
        ".": {
            "types": "./dist/core/index.d.ts",
            "import": "./dist/core/index.js",
            "default": "./dist/core/index.js"
        },
        "./vue": {
            "types": "./dist/vue/index.d.ts",
            "import": "./dist/vue/index.js",
            "default": "./dist/vue/index.js"
        },
        "./svelte": {
            "types": "./dist/svelte/index.d.ts",
            "import": "./dist/svelte/index.js",
            "default": "./dist/svelte/index.js"
        },
        "./react": {
            "types": "./dist/react/index.d.ts",
            "import": "./dist/react/index.js",
            "default": "./dist/react/index.js"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "tsdown",
        "types": "tsc --noEmit"
    },
    "peerDependencies": {
        "react": "^18.0.0 || ^19.0.0",
        "svelte": "^5.0.0",
        "vue": "^3.5"
    },
    "peerDependenciesMeta": {
        "react": {
            "optional": true
        },
        "svelte": {
            "optional": true
        },
        "vue": {
            "optional": true
        }
    },
    "devDependencies": {
        "@types/react": "^19.0.0",
        "react": "^19.0.0",
        "svelte": "^5.0.0",
        "tsdown": "^0.22.3"
    }
}
