{
    "name": "@oriui/headless",
    "version": "1.0.0-alpha.3",
    "description": "Framework-agnostic headless engine for oriUI + adapters (Vue at ./vue, Svelte at ./svelte) — tiny state machines + prop-getters behind a swappable contract",
    "license": "MIT",
    "type": "module",
    "sideEffects": false,
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public"
    },
    "exports": {
        ".": {
            "types": "./dist/core/index.d.ts",
            "import": "./dist/core/index.js",
            "default": "./dist/core/index.js"
        },
        "./vue": {
            "types": "./dist/vue/index.d.ts",
            "import": "./dist/vue/index.js",
            "default": "./dist/vue/index.js"
        },
        "./svelte": {
            "types": "./dist/svelte/index.d.ts",
            "import": "./dist/svelte/index.js",
            "default": "./dist/svelte/index.js"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "tsdown",
        "types": "tsc --noEmit"
    },
    "peerDependencies": {
        "svelte": "^5.0.0",
        "vue": "^3.5"
    },
    "peerDependenciesMeta": {
        "svelte": {
            "optional": true
        },
        "vue": {
            "optional": true
        }
    },
    "devDependencies": {
        "svelte": "^5.0.0",
        "tsdown": "^0.22.3"
    }
}
